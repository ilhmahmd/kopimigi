# ─── Supabase ─────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ⚠️  SENSITIVE: Get service role key from Supabase Dashboard → Settings → API
# DO NOT commit this to version control!
# Only add this to .env for local development
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Photobooth ───────────────────────────────────────────────
# URL where the booth station is accessible (used to build QR code URLs)
# In production: https://booth.yourcoffee.com
# In development: http://localhost:5174
VITE_BOOTH_BASE_URL=http://localhost:5174

# ─── App Config ───────────────────────────────────────────────
VITE_COFFEE_SHOP_NAME=kopimigi
VITE_PHOTO_SESSION_EXPIRE_MINUTES=30
